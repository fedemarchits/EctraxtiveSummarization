# Copy to .env and fill in. Loaded automatically by deploy/run_docker.sh and
# forwarded into the container. .env is gitignored — never commit real secrets.

# HuggingFace: needed to download gated models (Gemma, some Qwen).
HF_TOKEN=hf_xxx

# Endpoint backend for the large tiers (qwen35_27b, gemma4_31b).
# OpenRouter is OpenAI-compatible — use its base URL + your OpenRouter key.
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-or-xxx
